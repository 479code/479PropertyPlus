# ============================================================================
# 479Property+ — Environment Variables (EXAMPLE)
#
# 1. Copy this file to `.env`  ->  cp .env.example .env
# 2. Replace every placeholder with a real value.
# 3. NEVER commit your real `.env`. It is git-ignored on purpose.
#
# Generate strong secrets with:  openssl rand -base64 48
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# API — NestJS (apps/api)
# ----------------------------------------------------------------------------
API_PORT=3000
API_GLOBAL_PREFIX=api
API_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Web — Vite / React (apps/web)
# NOTE: Vite only exposes variables prefixed with VITE_ to the browser bundle.
#       Never put server secrets behind a VITE_ prefix.
# ----------------------------------------------------------------------------
WEB_PORT=5173
VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# ----------------------------------------------------------------------------
# Database — PostgreSQL / Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_plus?schema=public
# Optional shadow DB used by `prisma migrate` in some environments:
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_plus_shadow?schema=public

# ----------------------------------------------------------------------------
# Authentication — JWT
# Use LONG, RANDOM, and DISTINCT secrets for access vs refresh.
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-strong-random-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-different-strong-random-refresh-secret
JWT_REFRESH_TTL=7d
# Password hashing cost factor (bcrypt/argon2):
PASSWORD_HASH_ROUNDS=12

# ----------------------------------------------------------------------------
# Redis — cache + BullMQ queues
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Cloudinary — image/media hosting
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----------------------------------------------------------------------------
# AWS S3 — document storage / backups
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=property-plus-uploads

# ----------------------------------------------------------------------------
# Google Maps — server-side key (if used outside the browser)
# ----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-server-key

# ----------------------------------------------------------------------------
# Security — rate limiting & CORS
# ----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=debug
