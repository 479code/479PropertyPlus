# ============================================================================
# 479Property+ — Environment Variables (EXAMPLE)
#
# 1. Copy this file to `.env`  ->  cp .env.example .env
# 2. Replace every placeholder with a real value.
# 3. NEVER commit your real `.env`. It is git-ignored on purpose.
#
# Generate strong secrets with:  openssl rand -base64 48
# ============================================================================

# ---- Runtime ----
NODE_ENV=development

# ---- API (NestJS · apps/api) ----
API_PORT=3000
API_GLOBAL_PREFIX=api
API_URL=http://localhost:3000

# ---- Web (Vite · apps/web) ----
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
WEB_PORT=5173
VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# ---- Database (PostgreSQL / Prisma) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_plus?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_plus_shadow?schema=public

# ---- Docker Postgres (docker/docker-compose.yml) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=property_plus
POSTGRES_PORT=5432

PASSWORD_HASH_ROUNDS=12

# ---- Redis (cache + BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- AWS S3 ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=property-plus-uploads

# ---- Google Maps (server-side) ----
GOOGLE_MAPS_API_KEY=your-google-maps-server-key

# ---- Security ----
CORS_ORIGINS=http://localhost:5173

# ---- Logging ----
LOG_LEVEL=debug

# ── Authentication ──────────────────────────────────────────────
# REQUIRED in every environment. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TTL=900          # access token lifetime, seconds (15 min)
JWT_REFRESH_TTL_DAYS=7      # refresh token lifetime, days

# ── Invitations ─────────────────────────────────────────────────
INVITE_TTL_DAYS=7

# ── Rate limiting ───────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000    # window length, ms
RATE_LIMIT_MAX=100         # max requests per window per IP
