# ============================================================================
# 479Property+ — .gitignore
# Monorepo: pnpm + Turborepo · NestJS (api) · Vite/React (web) · Prisma
# ============================================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- pnpm ----
.pnpm-store/
.pnpm-debug.log*

# ---- Build outputs ----
dist/
build/
out/
*.tsbuildinfo
apps/api/dist/
apps/web/dist/

# ---- Turborepo ----
.turbo/

# ---- Vite ----
.vite/

# ---- Environment (never commit real secrets) ----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example

# ---- Prisma ----
# Migrations ARE committed. The generated client is not (it lives in node_modules).
# Local SQLite/dev artifacts, if any:
*.db
*.db-journal

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Testing / coverage ----
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/
blob-report/

# ---- Caches ----
.cache/
.eslintcache
.parcel-cache/
.rollup.cache/

# ---- IDE / editors ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Docker ----
# Compose files are committed; local overrides are not.
docker-compose.override.yml

# ---- Temp ----
tmp/
temp/
*.tmp
