# Normalize line endings to LF in the repo; check out as-is on each OS.
* text=auto eol=lf

# Explicitly LF for source/config
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.prisma text eol=lf
.husky/* text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
