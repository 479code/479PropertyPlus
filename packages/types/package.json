{
  "name": "@479property/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types and contracts for 479Property+.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@479property/config": "workspace:*",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
