// ════════════════════════════════════════════════════════════════════
//  Milestone 005 — Tenant, Contact & CRM Management
// ════════════════════════════════════════════════════════════════════

enum PersonDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENCE
  UTILITY_BILL
  EMPLOYMENT_LETTER
  COMPANY_REGISTRATION
  TAX_CERTIFICATE
  OTHER
}

enum ContactHistoryType {
  CALL
  EMAIL
  MEETING
  NOTE
  SMS
  WHATSAPP
}

/// Configurable, organization-scoped role vocabulary (Tenant, Owner, Agent, etc).
/// A Person may hold several of these simultaneously via PersonRole.
model PersonType {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  roles PersonRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("person_types")
}

/// Configurable, organization-scoped tag vocabulary (VIP, Blacklisted, etc).
model PersonTag {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  color        String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  assignments PersonTagAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("person_tags")
}

/// The single, canonical record for any individual known to an organization —
/// tenants, owners, agents, guarantors, and emergency contacts are all Persons,
/// distinguished by which PersonRole rows they hold (never duplicated per role).
model Person {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  personCode String
  slug       String

  firstName  String
  middleName String?
  lastName   String
  fullName   String

  gender               String?
  dateOfBirth          DateTime?
  maritalStatus        String?
  nationality          String?
  occupation           String?

  email          String?
  phone          String?
  alternatePhone String?
  profilePhoto   String?

  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?

  identificationType     String?
  identificationNumber   String?
  identificationExpiry   DateTime?
  taxIdentificationNumber String?

  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  roles              PersonRole[]
  tenantProfile      TenantProfile?
  ownerProfile       OwnerProfile?
  agentProfile       AgentProfile?
  documents          PersonDocument[]
  tagAssignments     PersonTagAssignment[]
  contactHistory     ContactHistoryEntry[]
  emergencyContactsOf   EmergencyContact[] @relation("EmergencyContactOwner")
  emergencyContactEntries EmergencyContact[] @relation("EmergencyContactPerson")
  companyContactFor  Company[]
  primaryTenantLeases Lease[] @relation("PrimaryTenantLeases")
  leaseTenancies     LeaseTenant[]
  leaseGuarantees    LeaseGuarantor[]

  @@unique([organizationId, personCode])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([email])
  @@index([phone])
  @@map("people")
}

/// Junction table: which roles (PersonType) a Person currently holds.
model PersonRole {
  id           String     @id @default(uuid()) @db.Uuid
  personId     String     @db.Uuid
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  personTypeId String     @db.Uuid
  personType   PersonType @relation(fields: [personTypeId], references: [id])

  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([personId, personTypeId])
  @@index([personId])
  @@index([personTypeId])
  @@map("person_roles")
}

/// A corporate entity — the counterpart for corporate tenants, corporate owners, etc.
model Company {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyName        String
  registrationNumber String?
  taxNumber          String?
  email              String?
  phone              String?
  website            String?
  address            String?

  contactPersonId String? @db.Uuid
  contactPerson   Person? @relation(fields: [contactPersonId], references: [id], onDelete: SetNull)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  tenantProfiles TenantProfile[]

  @@index([organizationId])
  @@index([deletedAt])
  @@index([contactPersonId])
  @@map("companies")
}

model TenantProfile {
  id       String @id @default(uuid()) @db.Uuid
  personId String @unique @db.Uuid
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  companyId String?  @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  employmentStatus       String?
  employer               String?
  monthlyIncome          Decimal? @db.Decimal(18, 2)
  preferredPaymentMethod String?
  preferredCommunication String?
  riskRating             String?
  creditScore            Int?
  status                 String?

  /// Convenience default for future lease creation flows — NOT an active
  /// guarantee record. Real guarantees are GuarantorAssignment (Milestone 006),
  /// scoped to a specific Lease. This is only a suggested default person to
  /// pre-fill when starting that flow.
  defaultGuarantorPersonId String? @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@index([companyId])
  @@map("tenant_profiles")
}

model AgentProfile {
  id       String @id @default(uuid()) @db.Uuid
  personId String @unique @db.Uuid
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  agencyName     String?
  commissionRate Decimal? @db.Decimal(5, 2)
  licenceNumber  String?
  territory      String?
  notes          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@map("agent_profiles")
}

model OwnerProfile {
  id       String @id @default(uuid()) @db.Uuid
  personId String @unique @db.Uuid
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  ownershipType    String?
  /// Metadata only — no raw bank account numbers should be stored without
  /// dedicated encryption-at-rest handling; kept as free-form Json for now
  /// (e.g. { bankName, accountName } — NOT full account numbers).
  bankDetails      Json?
  payoutPreference String?
  notes            String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@map("owner_profiles")
}

/// A Person→Person relationship: `person` designates `contactPerson` as their
/// emergency contact.
model EmergencyContact {
  id     String @id @default(uuid()) @db.Uuid

  personId String @db.Uuid
  person   Person @relation("EmergencyContactOwner", fields: [personId], references: [id], onDelete: Cascade)

  contactPersonId String @db.Uuid
  contactPerson   Person @relation("EmergencyContactPerson", fields: [contactPersonId], references: [id], onDelete: Cascade)

  relationship String
  priority     Int     @default(0)
  isPrimary    Boolean @default(false)
  notes        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([personId, contactPersonId])
  @@index([personId])
  @@index([contactPersonId])
  @@map("emergency_contacts")
}

model PersonDocument {
  id       String @id @default(uuid()) @db.Uuid
  personId String @db.Uuid
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  documentType PersonDocumentType
  name         String
  url          String
  description  String?
  uploadedBy   String?            @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
  @@index([documentType])
  @@map("person_documents")
}

model PersonTagAssignment {
  id       String    @id @default(uuid()) @db.Uuid
  personId String    @db.Uuid
  person   Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  tagId    String    @db.Uuid
  tag      PersonTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([personId, tagId])
  @@index([tagId])
  @@map("person_tag_assignments")
}

/// Every recorded interaction (call, email, meeting, note, SMS, WhatsApp)
/// becomes a timeline event for a Person.
model ContactHistoryEntry {
  id       String @id @default(uuid()) @db.Uuid
  personId String @db.Uuid
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  type       ContactHistoryType
  subject    String?
  notes      String?
  occurredAt DateTime            @default(now())
  performedBy String?            @db.Uuid

  createdAt DateTime @default(now())

  @@index([personId])
  @@index([type])
  @@index([occurredAt])
  @@map("contact_history_entries")
}

// ─────────────────────────────────────────────────────────────────────────
// Milestone 006 — Lease & Occupancy Management
// ─────────────────────────────────────────────────────────────────────────

enum LeaseTenantRole {
  PRIMARY
  CO_TENANT
  OCCUPANT
  AUTHORIZED_REPRESENTATIVE
}

enum LeaseDocumentType {
  LEASE_AGREEMENT
  SIGNED_CONTRACT
  ADDENDUM
  IDENTITY_DOCUMENT
  INSPECTION_REPORT
  HANDOVER_REPORT
  OTHER
}

enum LeaseTimelineEvent {
  CREATED
  SUBMITTED
  APPROVED
  REJECTED
  SIGNED
  ACTIVATED
  RENEWAL_INITIATED
  RENEWED
  EXTENDED
  EXPIRED
  TERMINATED
  ARCHIVED
}

/// Org-scoped, seeded: Residential, Commercial, Office, Warehouse, Short Stay,
/// Monthly, Annual, Corporate, Staff Accommodation.
model LeaseType {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  name           String
  description    String?
  displayOrder   Int     @default(0)
  isActive       Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  leases Lease[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("lease_types")
}

/// Org-scoped, seeded: Weekly, Monthly, Quarterly, Bi-Annual, Annual, Custom.
model PaymentFrequency {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  name           String
  description    String?
  displayOrder   Int     @default(0)
  isActive       Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  leases Lease[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("payment_frequencies")
}

/// Org-scoped lease lifecycle states. `key` is the stable, code-referenced
/// identifier (DRAFT, PENDING_APPROVAL, REJECTED, AWAITING_SIGNATURE, ACTIVE,
/// RENEWAL_PENDING, EXPIRED, TERMINATED, ARCHIVED); `name` is the editable
/// display label. `blocksUnitAvailability` / `countsAsOccupancy` drive the
/// occupancy engine and overlap validation — never hardcoded by key in
/// business logic, always read from these flags.
model LeaseStatus {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  key            String
  name           String
  color          String?
  description    String?
  displayOrder   Int     @default(0)
  isActive       Boolean @default(true)

  blocksUnitAvailability Boolean @default(false)
  countsAsOccupancy      Boolean @default(false)
  /// System statuses back the state machine and must not be deleted (only relabeled/recolored).
  isSystem               Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  leases          Lease[]
  fromTransitions LeaseStateTransition[] @relation("FromStatus")
  toTransitions   LeaseStateTransition[] @relation("ToStatus")

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("lease_statuses")
}

/// Data-driven state machine edges, per the approved architecture: transitions
/// are rows here, not a hardcoded switch statement, so they can be edited
/// later without a code change.
model LeaseStateTransition {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  fromStatusId   String @db.Uuid
  toStatusId     String @db.Uuid

  fromStatus LeaseStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   LeaseStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([organizationId, fromStatusId, toStatusId])
  @@index([organizationId])
  @@map("lease_state_transitions")
}

model Lease {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  leaseNumber    String
  leaseReference String?
  slug           String

  propertyId      String  @db.Uuid
  buildingId      String? @db.Uuid
  unitId          String  @db.Uuid
  primaryTenantId String  @db.Uuid
  leaseTypeId     String  @db.Uuid
  leaseStatusId   String  @db.Uuid

  property      Property         @relation(fields: [propertyId], references: [id])
  building      Building?        @relation(fields: [buildingId], references: [id])
  unit          Unit             @relation(fields: [unitId], references: [id])
  primaryTenant Person           @relation("PrimaryTenantLeases", fields: [primaryTenantId], references: [id])
  leaseType     LeaseType        @relation(fields: [leaseTypeId], references: [id])
  leaseStatus   LeaseStatus      @relation(fields: [leaseStatusId], references: [id])

  leaseStartDate DateTime
  leaseEndDate   DateTime
  moveInDate     DateTime?
  moveOutDate    DateTime?

  leaseDurationMonths Int?
  renewalNoticeDays   Int?
  gracePeriodDays     Int?

  securityDeposit      Decimal? @db.Decimal(18, 2)
  monthlyRent          Decimal? @db.Decimal(18, 2)
  annualRent           Decimal? @db.Decimal(18, 2)
  serviceCharge        Decimal? @db.Decimal(18, 2)
  utilityCharge        Decimal? @db.Decimal(18, 2)
  parkingCharge        Decimal? @db.Decimal(18, 2)
  discount             Decimal? @db.Decimal(18, 2)
  taxAmount            Decimal? @db.Decimal(18, 2)
  totalRecurringAmount Decimal? @db.Decimal(18, 2)

  paymentFrequencyId String?           @db.Uuid
  paymentFrequency   PaymentFrequency? @relation(fields: [paymentFrequencyId], references: [id])
  billingCycle       String?
  nextInvoiceDate    DateTime?
  autoRenew          Boolean           @default(false)

  signedDate        DateTime?
  terminationDate   DateTime?
  terminationReason String?
  notes             String?
  isActive          Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  tenants    LeaseTenant[]
  guarantors LeaseGuarantor[]
  documents  LeaseDocument[]
  timeline   LeaseTimelineEntry[]
  notesLog   LeaseNote[]

  @@unique([organizationId, leaseNumber])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([unitId])
  @@index([leaseStatusId])
  @@index([primaryTenantId])
  @@index([leaseStartDate])
  @@index([leaseEndDate])
  @@index([deletedAt])
  @@map("leases")
}

model LeaseTenant {
  id                  String           @id @default(uuid()) @db.Uuid
  leaseId             String           @db.Uuid
  personId            String           @db.Uuid
  role                LeaseTenantRole  @default(CO_TENANT)
  ownershipPercentage Decimal?         @db.Decimal(5, 2)

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id])

  createdAt DateTime @default(now())

  @@unique([leaseId, personId])
  @@index([personId])
  @@map("lease_tenants")
}

/// The deferred M005 "GuarantorAssignment", now buildable since Lease exists.
model LeaseGuarantor {
  id                   String   @id @default(uuid()) @db.Uuid
  leaseId              String   @db.Uuid
  personId             String   @db.Uuid
  guaranteeType        String?
  guaranteeAmount      Decimal? @db.Decimal(18, 2)
  relationshipToTenant String?
  status               String?
  notes                String?

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leaseId, personId])
  @@index([personId])
  @@map("lease_guarantors")
}

model LeaseDocument {
  id           String            @id @default(uuid()) @db.Uuid
  leaseId      String            @db.Uuid
  documentType LeaseDocumentType
  name         String
  url          String
  description  String?
  uploadedBy   String?           @db.Uuid

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leaseId])
  @@map("lease_documents")
}

model LeaseTimelineEntry {
  id          String             @id @default(uuid()) @db.Uuid
  leaseId     String             @db.Uuid
  eventType   LeaseTimelineEvent
  description String?
  metadata    Json?
  performedBy String?            @db.Uuid

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leaseId])
  @@map("lease_timeline_entries")
}

model LeaseNote {
  id       String  @id @default(uuid()) @db.Uuid
  leaseId  String  @db.Uuid
  authorId String? @db.Uuid
  note     String

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leaseId])
  @@map("lease_notes")
}
