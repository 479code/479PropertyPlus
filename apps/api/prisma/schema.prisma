// 479Property+ — Prisma schema
// Foundation: multi-organization authentication + System Configuration Engine.
// Primary keys: UUID (@db.Uuid) across every table. Soft deletes + audit fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════════
//  Enums
// ════════════════════════════════════════════════════════════════════

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum ConfigurationCategory {
  PROPERTY_TYPE
  BUILDING_TYPE
  UNIT_TYPE
  OCCUPANCY_STATUS
  PROPERTY_STATUS
  LEASE_TYPE
  LEASE_STATUS
  PAYMENT_METHOD
  PAYMENT_FREQUENCY
}

enum LateFeeType {
  FIXED
  PERCENTAGE
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationEvent {
  RENT_DUE
  PAYMENT_RECEIVED
  LEASE_EXPIRY
  WELCOME_TENANT
}

enum NumberedEntity {
  PROPERTY
  BUILDING
  FLOOR
  UNIT
  PERSON
  TENANT
  LEASE
  INVOICE
  RECEIPT
  PAYMENT
  MAINTENANCE_TICKET
  INSPECTION
}

enum SequenceResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

enum FeatureKey {
  MAINTENANCE
  INSPECTION
  AI
  OWNER_PORTAL
  TENANT_PORTAL
  REPORTS
  ACCOUNTING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  LOGIN
  LOGOUT
}

// ════════════════════════════════════════════════════════════════════
//  Identity — User is GLOBAL (no organizationId). Org membership is a join.
// ════════════════════════════════════════════════════════════════════

model User {
  id           String  @id @default(uuid()) @db.Uuid
  email        String  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  isActive     Boolean @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  memberships   Membership[]
  refreshTokens RefreshToken[]
  preference    UserPreference?
  auditLogs     AuditLog[]

  @@index([deletedAt])
  @@map("users")
}

model UserPreference {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                   String  @default("system")
  language                String  @default("en")
  timezone                String  @default("UTC")
  dateFormat              String  @default("YYYY-MM-DD")
  timeFormat              String  @default("HH:mm")
  landingPage             String  @default("/dashboard")
  notificationPreferences Json?
  sidebarCollapsed        Boolean @default(false)
  density                 String  @default("comfortable")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ════════════════════════════════════════════════════════════════════
//  Multi-org: Membership links a User to an Organization; roles hang off it.
// ════════════════════════════════════════════════════════════════════

model Membership {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  status MembershipStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  roles MembershipRole[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model Role {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  key         String
  name        String
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  permissions RolePermission[]
  members     MembershipRole[]
  invites     OrganizationInvite[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  resource    String
  action      String
  description String?

  createdAt DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @db.Uuid
  permissionId String @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MembershipRole {
  id           String @id @default(uuid()) @db.Uuid
  membershipId String @db.Uuid
  roleId       String @db.Uuid
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([membershipId, roleId])
  @@index([roleId])
  @@map("membership_roles")
}

model RefreshToken {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  userAgent    String?
  ipAddress    String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model OrganizationInvite {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email     String
  roleId    String       @db.Uuid
  role      Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tokenHash String       @unique
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid

  @@index([organizationId])
  @@index([email])
  @@map("organization_invites")
}

// ════════════════════════════════════════════════════════════════════
//  Tenant root
// ════════════════════════════════════════════════════════════════════

model Organization {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  // Auth relations
  memberships Membership[]
  roles       Role[]
  invites     OrganizationInvite[]
  refreshTokens RefreshToken[]

  // Configuration relations
  organizationSettings OrganizationSettings?
  leaseSettings        LeaseSettings?
  paymentSettings      PaymentSettings?
  notificationSettings NotificationSettings?
  configurationOptions ConfigurationOption[]
  lateFeeRules         LateFeeRule[]
  notificationTemplates NotificationTemplate[]
  numberingSequences   NumberingSequence[]
  featureFlags         FeatureFlag[]
  auditLogs            AuditLog[]

  // Property foundation relations
  propertyTypes    PropertyType[]
  propertyStatuses PropertyStatus[]
  propertyFeatures PropertyFeature[]
  propertyTags     PropertyTag[]
  properties       Property[]

  // Inventory relations
  buildingStatuses BuildingStatus[]
  unitTypes        UnitType[]
  unitStatuses     UnitStatus[]
  unitFeatures     UnitFeature[]
  buildings        Building[]
  floors           Floor[]
  units            Unit[]

  // CRM relations
  personTypes    PersonType[]
  personTags     PersonTag[]
  people         Person[]
  companies      Company[]

  @@index([deletedAt])
  @@map("organizations")
}

// ════════════════════════════════════════════════════════════════════
//  1. Organization Settings (singleton per org)
// ════════════════════════════════════════════════════════════════════

model OrganizationSettings {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyName        String?
  logoUrl            String?
  theme              String  @default("light")
  currency           String  @default("USD")
  timezone           String  @default("UTC")
  language           String  @default("en")
  dateFormat         String  @default("YYYY-MM-DD")
  timeFormat         String  @default("HH:mm")
  numberFormat       String  @default("1,234.56")
  fiscalYearStartMonth Int   @default(1)
  fiscalYearStartDay   Int   @default(1)
  financialYearStart DateTime?
  workingDays        Int[]   @default([1, 2, 3, 4, 5])
  weekendDays        Int[]   @default([0, 6])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@map("organization_settings")
}

// ════════════════════════════════════════════════════════════════════
//  2/3/4. Generic configurable options (property/lease/payment lists)
// ════════════════════════════════════════════════════════════════════

model ConfigurationOption {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category    ConfigurationCategory
  key         String
  label       String
  description String?
  color       String?
  icon        String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false)
  metadata    Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@unique([organizationId, category, key])
  @@index([organizationId, category])
  @@index([deletedAt])
  @@map("configuration_options")
}

// ════════════════════════════════════════════════════════════════════
//  3. Lease Settings (singleton) + Late Fee Rules
// ════════════════════════════════════════════════════════════════════

model LeaseSettings {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  renewalNoticePeriodDays Int     @default(30)
  gracePeriodDays         Int     @default(0)
  autoRenew               Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@map("lease_settings")
}

model LateFeeRule {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  feeType       LateFeeType
  amount        Decimal  @db.Decimal(12, 2)
  applyAfterDays Int     @default(0)
  maxAmount     Decimal? @db.Decimal(12, 2)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@index([organizationId])
  @@index([deletedAt])
  @@map("late_fee_rules")
}

// ════════════════════════════════════════════════════════════════════
//  4. Payment Settings (singleton)
// ════════════════════════════════════════════════════════════════════

model PaymentSettings {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoicePrefix  String  @default("INV")
  receiptPrefix  String  @default("RCP")
  currencySymbol String  @default("$")
  taxEnabled     Boolean @default(false)
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
  vatEnabled     Boolean @default(false)
  vatRate        Decimal @default(0) @db.Decimal(5, 2)
  taxInclusive   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@map("payment_settings")
}

// ════════════════════════════════════════════════════════════════════
//  5. Notification Settings (singleton) + Templates
// ════════════════════════════════════════════════════════════════════

model NotificationSettings {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(false)
  whatsappEnabled Boolean @default(false)
  pushEnabled     Boolean @default(false)
  inAppEnabled    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@map("notification_settings")
}

model NotificationTemplate {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  event   NotificationEvent
  channel NotificationChannel
  subject String?
  body    String  @db.Text
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  @@unique([organizationId, event, channel])
  @@index([organizationId])
  @@map("notification_templates")
}

// ════════════════════════════════════════════════════════════════════
//  6. Numbering Engine
// ════════════════════════════════════════════════════════════════════

model NumberingSequence {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entity          NumberedEntity
  prefix          String              @default("")
  suffix          String              @default("")
  padding         Int                 @default(6)
  separator       String              @default("-")
  includeYear     Boolean             @default(false)
  resetPolicy     SequenceResetPolicy @default(NEVER)
  currentValue    Int                 @default(0)
  lastResetPeriod String?
  isActive        Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@unique([organizationId, entity])
  @@index([organizationId])
  @@map("numbering_sequences")
}

// ════════════════════════════════════════════════════════════════════
//  7. Feature Flags
// ════════════════════════════════════════════════════════════════════

model FeatureFlag {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  feature   FeatureKey
  isEnabled Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  @@unique([organizationId, feature])
  @@index([organizationId])
  @@map("feature_flags")
}

// ════════════════════════════════════════════════════════════════════
//  8. Audit Log
// ════════════════════════════════════════════════════════════════════

model AuditLog {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String? @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  userId      String? @db.Uuid
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      AuditAction
  entityType  String
  entityId    String?
  description String?
  changes     Json?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  @@index([organizationId, entityType])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════════════════
//  Milestone 003 — Geographic hierarchy (GLOBAL, not org-scoped) +
//  Property foundation (org-scoped).
// ════════════════════════════════════════════════════════════════════

enum DocumentType {
  TITLE
  SURVEY
  CERTIFICATE
  INSURANCE
  BUILDING_PLAN
  UTILITY
  PURCHASE_AGREEMENT
  LEASE
  OTHER
}

enum PropertyOwnerType {
  INDIVIDUAL
  COMPANY
  GOVERNMENT
  TRUST
  OTHER
}

// ── Geographic hierarchy (global reference data) ─────────────────────

model Country {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  isoCode  String  @unique
  currency String?
  timezone String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  states     State[]
  properties Property[]

  @@map("countries")
}

model State {
  id        String  @id @default(uuid()) @db.Uuid
  countryId String  @db.Uuid
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name      String
  code      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cities     City[]
  properties Property[]

  @@unique([countryId, name])
  @@index([countryId])
  @@map("states")
}

model City {
  id      String @id @default(uuid()) @db.Uuid
  stateId String @db.Uuid
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  name    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts  District[]
  properties Property[]

  @@unique([stateId, name])
  @@index([stateId])
  @@map("cities")
}

model District {
  id     String @id @default(uuid()) @db.Uuid
  cityId String @db.Uuid
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  name   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas      Area[]
  properties Property[]

  @@unique([cityId, name])
  @@index([cityId])
  @@map("districts")
}

model Area {
  id         String   @id @default(uuid()) @db.Uuid
  districtId String   @db.Uuid
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]

  @@unique([districtId, name])
  @@index([districtId])
  @@map("areas")
}

// ── Property configuration (org-scoped, seeded per organization) ─────

model PropertyType {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  icon         String?
  color        String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  properties Property[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("property_types")
}

model PropertyStatus {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  color        String?
  description  String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  properties Property[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("property_statuses")
}

model PropertyFeature {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name         String
  icon         String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  assignments PropertyFeatureAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("property_features")
}

model PropertyTag {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name  String
  color String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  assignments PropertyTagAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("property_tags")
}

// ── Property entity ──────────────────────────────────────────────────

model Property {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  propertyCode String
  slug         String
  name         String
  description  String?

  propertyTypeId String       @db.Uuid
  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id])
  statusId       String         @db.Uuid
  status         PropertyStatus @relation(fields: [statusId], references: [id])

  countryId  String?   @db.Uuid
  country    Country?  @relation(fields: [countryId], references: [id])
  stateId    String?   @db.Uuid
  state      State?    @relation(fields: [stateId], references: [id])
  cityId     String?   @db.Uuid
  city       City?     @relation(fields: [cityId], references: [id])
  districtId String?   @db.Uuid
  district   District? @relation(fields: [districtId], references: [id])
  areaId     String?   @db.Uuid
  area       Area?     @relation(fields: [areaId], references: [id])

  streetAddress String?
  postalCode    String?

  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  polygon     Json?
  geoJson     Json?
  googlePlaceId String?

  yearBuilt             Int?
  purchaseDate          DateTime?
  purchasePrice         Decimal?  @db.Decimal(18, 2)
  marketValue           Decimal?  @db.Decimal(18, 2)
  expectedAnnualRevenue Decimal?  @db.Decimal(18, 2)

  ownerType         PropertyOwnerType?
  ownerReferenceId  String?            @db.Uuid

  totalBuildings Int @default(0)
  totalUnits     Int @default(0)
  occupiedUnits  Int @default(0)
  vacantUnits    Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?

  images    PropertyImage[]
  documents PropertyDocument[]
  features  PropertyFeatureAssignment[]
  tags      PropertyTagAssignment[]

  buildings Building[]
  units     Unit[]
  leases    Lease[]

  @@unique([organizationId, propertyCode])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([propertyCode])
  @@index([slug])
  @@index([propertyTypeId])
  @@index([statusId])
  @@index([countryId])
  @@index([stateId])
  @@index([cityId])
  @@index([districtId])
  @@index([areaId])
  @@index([googlePlaceId])
  @@index([deletedAt])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  url       String
  caption   String?
  sortOrder Int     @default(0)
