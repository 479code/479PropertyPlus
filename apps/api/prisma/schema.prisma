enum UnitDocumentType {
  FLOOR_PLAN
  INSPECTION_REPORT
  WARRANTY
  CERTIFICATE
  MAINTENANCE_MANUAL
  OTHER
}

// Ordered by resolution precedence (highest first); AvailabilityService is the source of truth.
enum UnitAvailability {
  ARCHIVED
  INACTIVE
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
  BLOCKED
  AVAILABLE
}

enum UnitTimelineEvent {
  CREATED
  UPDATED
  RESERVED
  MAINTENANCE_STARTED
  MAINTENANCE_COMPLETED
  LEASE_STARTED
  LEASE_ENDED
  ARCHIVED
  RESTORED
  AVAILABILITY_CHANGED
}

// ── Inventory configuration (org-scoped, seeded per organization) ────

